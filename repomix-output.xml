// src/app/settings/feedback/page.tsx
"use client";

import { useState } from "react";

// Placeholder for your actual external feedback form URL (e.g., Google Form, Typeform)
const EXTERNAL_FEEDBACK_FORM_URL = "https://docs.google.com/forms/d/1hDMhLdFbvVte_WHDgz3GaDXm9qQq6ElLuGfGavy98nw/viewform";

export default function FeedbackPage() {
  const [hasClicked, setHasClicked] = useState(false); 

  const handleClick = () => {
    // In a real application, you might log the click event to Supabase here.
    setHasClicked(true);
  };

  return (
    <section className="main-content">
      <div className="container" style={{ textAlign: 'center' }}>
        
        {/* IMPROVEMENT 1: New Title Text and Center Alignment */}
        <h2 style={{ marginBottom: 24, marginTop: 40 }}>Your Feedback & Ideas</h2> 
        
        <div className="card" style={{ maxWidth: 500, margin: '0 auto', padding: '30px' }}>
          <div className="card__body" style={{ textAlign: 'center' }}>
            
            {!hasClicked ? (
              <>
                {/* IMPROVEMENT 2: New Flow Text */}
                <p className="section-description" style={{ marginBottom: 20, fontSize: '1.1rem', fontWeight: 500 }}>
                  Ready to share your insights? We thrive on suggestions, bug reports, and feature ideas from clinicians like you.
                </p>
                <p className="section-description" style={{ marginBottom: 30, color: 'var(--umbil-muted)' }}>
                  Click below to submit your feedback via our secure external form. It only takes a minute!
                </p>

                <a 
                  className="btn btn--primary" 
                  href={EXTERNAL_FEEDBACK_FORM_URL}
                  target="_blank" 
                  rel="noopener noreferrer"
                  onClick={handleClick}
                >
                  📝 Open Feedback Form
                </a>
              </>
            ) : (
              <div style={{ padding: '20px 0' }}>
                <h3 style={{color: 'var(--umbil-brand-teal)', marginBottom: 12}}>Thank You!</h3>
                <p>The feedback form should have opened in a new window. We appreciate your input.</p>
                <button 
                    className="btn btn--outline" 
                    style={{marginTop: 20}}
                    onClick={() => setHasClicked(false)}
                >
                    Back to Feedback Page
                </button>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  );
}
</file>

<file path="src/app/styles/chat.css">
/* src/app/styles/chat.css */
.conversation-container {
  width: 100%;
  flex-grow: 1;
  overflow-y: auto;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center; 
}

.message-thread {
  width: 100%;
  max-width: 900px; 
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 24px;
  padding-bottom: 120px;
}

.sticky-input-wrapper {
  position: sticky;
  bottom: 0;
  width: 100%;
  background: var(--umbil-bg);
  border-top: 1px solid var(--umbil-divider);
  z-index: 50;
  padding: 16px 20px 24px 20px;
  display: flex;
  justify-content: center;
}

.message-bubble {
  min-width: 0; 
  word-wrap: break-word;
  padding: 16px;
  border-radius: var(--umbil-radius-sm);
  box-shadow: var(--umbil-shadow-sm);
  max-width: 85%;
  animation: fadeIn 0.5s ease-out;
  transition: background-color 0.3s, border-color 0.3s;
}

.user-message {
  background-color: #e6f7ff;
  margin-left: auto;
}

.umbil-message {
  background-color: var(--umbil-surface);
  border: 1px solid var(--umbil-card-border);
  margin-right: auto;
  position: relative;
  line-height: 1.6;
}

/* Dark mode specific for chat */
.dark .user-message { background-color: #004d4d; color: var(--umbil-text); }
.dark .umbil-message { background-color: var(--umbil-surface); border: 1px solid var(--umbil-card-border); }

/* Markdown & Tables */
.markdown-content-wrapper { width: 100%; overflow: hidden; }
.table-scroll-wrapper {
  display: block; width: 100%; overflow-x: auto;
  -webkit-overflow-scrolling: touch; margin: 1em 0;
  border: 1px solid var(--umbil-divider);
  border-radius: 8px; background: var(--umbil-surface);
}
.table-scroll-wrapper table { width: 100%; border-collapse: collapse; min-width: 600px; }
.markdown-content-wrapper th, .markdown-content-wrapper td {
  padding: 12px; border-bottom: 1px solid var(--umbil-divider); text-align: left; font-size: 0.9rem;
}

.umbil-message p { margin: 0 0 1rem 0; }
.umbil-message p:last-child { margin-bottom: 0; }
.umbil-message ul, .umbil-message ol { margin: 1rem 0 1rem 1.5rem; padding: 0; }
.umbil-message li { margin-bottom: 0.5rem; }
.umbil-message h1, .umbil-message h2, .umbil-message h3 { font-weight: 700; margin-top: 1.5rem; margin-bottom: 0.5rem; }
.umbil-message strong { font-weight: 700; }

.umbil-message-actions {
  display: flex; flex-wrap: wrap; gap: 16px; margin-top: 1rem;
  padding-top: 0.75rem; border-top: 1px solid var(--umbil-divider);
  justify-content: flex-start; opacity: 1;
}

.loading-indicator {
  display: flex; align-items: center; gap: 8px; color: var(--umbil-muted); font-size: 14px;
}

/* Ask Bar Styles */
.ask-bar-container-new {
  width: 100%;
  background-color: var(--umbil-surface);
  border: 1px solid rgba(31, 184, 205, 0.3);
  border-radius: var(--umbil-radius-sm);
  box-shadow: var(--umbil-shadow-sm);
  display: flex; flex-direction: column; padding: 12px 16px;
  transition: box-shadow 0.2s, border-color 0.2s;
}

.ask-bar-container-new:focus-within {
  box-shadow: 0 0 0 3px rgba(31, 184, 205, 0.15); border-color: var(--umbil-brand-teal);
}

.ask-bar-textarea {
  width: 100%; border: none; background: transparent;
  font-family: inherit; font-size: 1rem; color: var(--umbil-text);
  resize: none; outline: none; padding: 0; margin-bottom: 8px;
  max-height: 200px; min-height: 24px;
}

.ask-bar-actions { display: flex; justify-content: space-between; align-items: center; }

.action-icon-btn {
  background: transparent; border: none; cursor: pointer; padding: 8px;
  border-radius: var(--umbil-radius-sm); color: var(--umbil-muted);
  transition: background-color 0.2s, color 0.2s;
  display: flex; align-items: center; justify-content: center;
}
.action-icon-btn:hover { background-color: var(--umbil-hover-bg); color: var(--umbil-text); }
.action-icon-btn[title="Medical Tools"] { border-radius: var(--umbil-radius-sm); padding: 6px 10px; background-color: var(--umbil-hover-bg); color: var(--umbil-text); }
.action-icon-btn[title="Medical Tools"]:hover { background-color: #e2e8f0; }
:root .dark .action-icon-btn[title="Medical Tools"]:hover { background-color: #3f3f46; }

.send-icon-btn {
  background-color: var(--umbil-brand-teal); color: var(--umbil-surface);
  border: none; border-radius: var(--umbil-radius-sm);
  width: 36px; height: 36px; display: flex; justify-content: center; align-items: center;
  cursor: pointer; transition: transform 0.1s, opacity 0.2s;
}
.send-icon-btn:hover { opacity: 0.9; }
.send-icon-btn:disabled { background-color: var(--umbil-brand-teal); opacity: 0.4; cursor: not-allowed; }

/* Style Dropdown */
.style-dropdown-container { position: relative; z-index: 5; flex-shrink: 0; }
.style-dropdown-button {
  background-color: var(--umbil-surface); color: var(--umbil-muted);
  border: none; border-radius: var(--umbil-radius-sm); padding: 6px 10px;
  font-size: 0.85rem; font-weight: 600; cursor: pointer;
  display: flex; align-items: center; gap: 4px; transition: background-color 0.2s, color 0.2s;
}
.style-dropdown-button:hover { background-color: var(--umbil-hover-bg); color: var(--umbil-text); }

.style-dropdown-menu {
  position: absolute; bottom: 100%; left: 0; margin-bottom: 8px; min-width: 200px;
  background-color: var(--umbil-surface); border-radius: var(--umbil-radius-sm);
  border: 1px solid var(--umbil-divider); box-shadow: var(--umbil-shadow-lg);
  z-index: 110; padding: 6px; display: flex; flex-direction: column; gap: 2px;
}
.style-dropdown-menu button {
  background: none; border: none; width: 100%; padding: 8px 12px;
  border-radius: 4px; text-align: left; cursor: pointer;
  transition: background-color 0.2s; color: var(--umbil-text);
}
.style-dropdown-menu button:hover { background-color: var(--umbil-hover-bg); }
.style-dropdown-menu button.active { background-color: var(--umbil-hover-bg); color: var(--umbil-brand-teal); }
.style-dropdown-menu button strong { display: block; font-weight: 600; font-size: 0.9rem; }
.style-dropdown-menu button p { font-size: 0.75rem; color: var(--umbil-muted); margin: 2px 0 0 0; }

@media (max-width: 768px) {
  .message-thread { padding: 10px; padding-bottom: 140px; }
  .message-bubble { max-width: 100%; padding: 14px; border-radius: 12px; }
  .user-message { max-width: 90%; }
  .umbil-message { max-width: 100%; margin-right: 0; }
  .sticky-input-wrapper { padding: 12px; }
}
</file>

<file path="src/app/styles/components.css">
/* src/app/styles/components.css */

/* Buttons & Inputs Override */
.btn, .action-button, button[class*="btn"], input, textarea, select {
  border-radius: var(--radius-boxy) !important;
}
.capture-input, .capture-btn { border-radius: var(--radius-boxy) !important; }

/* Standard Buttons */
.btn {
  padding: 10px 16px; border-radius: var(--umbil-radius-sm); font-weight: 600;
  cursor: pointer; transition: background-color 0.2s, color 0.2s, border-color 0.2s;
  font-size: 1rem; line-height: 1.5; text-align: center; display: inline-block; white-space: nowrap;
}
.btn--primary { background-color: var(--umbil-brand-teal); color: var(--umbil-surface); border: 1px solid var(--umbil-brand-teal); }
.btn--primary:hover { background-color: #1a92a5; border-color: #1a92a5; }
.btn--outline {
  background-color: transparent; color: var(--umbil-text); border: 1px solid var(--umbil-card-border);
  transition: background-color 0.2s, border-color 0.3s, color 0.3s;
}
.btn--outline:hover { background-color: var(--umbil-hover-bg); }
.btn:disabled { opacity: 0.6; cursor: not-allowed; }

.menu-button, .login-button {
  background: none; border: none; cursor: pointer; padding: 8px;
  color: var(--umbil-text); font-size: 16px; line-height: 1;
  border-radius: var(--umbil-radius-sm); transition: background-color 0.2s ease-in-out;
}
.menu-button:hover, .login-button:hover { background-color: var(--umbil-hover-bg); }

.login-link {
  border: 1px solid var(--umbil-card-border); border-radius: var(--umbil-radius-sm);
  padding: 8px 12px; font-weight: 500; transition: background-color 0.2s;
  color: var(--umbil-text);
}
.login-link:hover { background-color: var(--umbil-hover-bg); }

.new-chat-button {
  display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%;
  padding: 10px; margin-bottom: 16px !important; background-color: transparent;
  color: var(--umbil-brand-teal); border: 1px solid var(--umbil-brand-teal);
  border-radius: var(--umbil-radius-sm); font-weight: 600; font-size: 0.95rem;
  cursor: pointer; transition: all 0.2s ease-in-out;
}
.new-chat-button:hover { background-color: var(--umbil-brand-teal); color: white; box-shadow: 0 4px 10px rgba(31, 184, 205, 0.2); }

.action-button {
  font-size: 13px; color: var(--umbil-muted); text-decoration: none; cursor: pointer;
  background: none; border: none; padding: 4px; border-radius: var(--umbil-radius-sm);
  transition: color 0.2s, background-color 0.2s; display: inline-flex;
  align-items: center; gap: 6px; font-weight: 500;
}
.action-button:hover { text-decoration: none; color: var(--umbil-brand-teal); background-color: var(--umbil-hover-bg); }

/* Forms */
.form-group { margin-bottom: 1rem; }
.form-label { display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.875rem; color: var(--umbil-muted); }
.form-control {
  display: block; width: 100%; padding: 10px; font-size: 1rem; line-height: 1.5;
  color: var(--umbil-text); background-color: var(--umbil-surface);
  background-clip: padding-box; border: 1px solid var(--umbil-card-border);
  border-radius: var(--umbil-radius-sm); transition: border-color 0.15s, box-shadow 0.15s;
}
.form-control:focus { outline: none; border-color: var(--umbil-brand-teal); box-shadow: 0 0 0 3px var(--umbil-focus-ring); }

/* Modals & Toasts */
.modal-overlay {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background-color: rgba(0, 0, 0, 0.5); display: flex; justify-content: center; align-items: center; z-index: 200;
}
.modal-content {
  background-color: var(--umbil-surface); padding: 20px; border-radius: var(--umbil-radius-sm);
  width: 90%; max-width: 500px; box-shadow: var(--umbil-shadow-lg); position: relative;
  transition: background-color 0.3s; max-height: 90vh; overflow-y: auto; display: flex; flex-direction: column;
}
.close-button {
  position: absolute; top: 10px; right: 10px; background: none; border: none;
  cursor: pointer; padding: 10px; color: var(--umbil-muted); opacity: 0.6; transition: opacity 0.2s;
}
.close-button:hover { opacity: 1; }

.toast-container { position: fixed; bottom: 20px; right: 20px; z-index: 300; }
.toast {
  background-color: var(--umbil-text); color: var(--umbil-surface);
  padding: 12px 20px; border-radius: var(--umbil-radius-sm);
  box-shadow: var(--umbil-shadow-lg); animation: toastIn 0.3s ease-out;
}

/* Global Streak */
.global-streak {
  font-weight: 700; font-size: 1rem; color: var(--umbil-text); margin-right: 12px;
  padding: 8px 12px; border-radius: var(--umbil-radius-sm); background-color: var(--umbil-hover-bg);
  cursor: help; transition: opacity 0.3s;
}
.global-streak.faded { opacity: 0.5; }

/* CPD Streak Calendar */
.calendar-grid-container { display: flex; overflow-x: auto; direction: rtl; scrollbar-width: none; }
.calendar-grid-container::-webkit-scrollbar { display: none; }
.day-labels-column { display: flex; flex-direction: column; justify-content: space-between; margin-right: 5px; padding-top: 2px; direction: ltr; }
.day-label-item { height: 14px; font-size: 10px; font-weight: 500; color: var(--umbil-muted); text-align: right; line-height: 14px; }
.calendar-grid { display: grid; grid-template-rows: repeat(7, 1fr); grid-auto-flow: column; grid-auto-columns: 17px; gap: 3px; direction: ltr; }
.calendar-square { width: 14px; height: 14px; border-radius: 2px; background-color: var(--umbil-hover-bg); transition: background-color 0.2s, opacity 0.2s; }
.calendar-square.level-1 { background-color: var(--umbil-brand-teal); opacity: 0.3; }
.calendar-square.level-2 { background-color: var(--umbil-brand-teal); opacity: 0.5; }
.calendar-square.level-3 { background-color: var(--umbil-brand-teal); opacity: 0.7; }
.calendar-square.level-4 { background-color: var(--umbil-brand-teal); opacity: 1; }
.calendar-square.is-today { box-shadow: 0 0 0 1px var(--umbil-text); }
.color-legend { width: 14px; height: 14px; border-radius: 2px; display: inline-block; margin: 0 3px; background-color: var(--umbil-hover-bg); }
.color-legend.level-1 { background-color: var(--umbil-brand-teal); opacity: 0.3; }
.color-legend.level-2 { background-color: var(--umbil-brand-teal); opacity: 0.5; }
.color-legend.level-3 { background-color: var(--umbil-brand-teal); opacity: 0.7; }
.color-legend.level-4 { background-color: var(--umbil-brand-teal); opacity: 1; }

/* Reflection Modal Specifics */
.streak-display-modal {
  padding: 12px 16px; font-size: 1.1rem; font-weight: 600; color: var(--umbil-text);
  background-color: var(--umbil-hover-bg); border: 1px solid var(--umbil-card-border);
  border-radius: var(--umbil-radius-sm); margin-bottom: 20px; text-align: center;
}
.gmc-cluster-container { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 1rem; }
.gmc-button {
  background-color: transparent; border: 1px dashed var(--umbil-divider);
  color: var(--umbil-muted); font-size: 0.8rem; font-weight: 500;
  padding: 6px 10px; border-radius: var(--umbil-radius-sm); cursor: pointer; transition: all 0.2s;
}
.gmc-button:hover { border-color: var(--umbil-brand-teal); color: var(--umbil-brand-teal); background-color: var(--umbil-hover-bg); }

.generate-button-container { margin: 12px 0; display: flex; gap: 12px; }
.generate-button {
  flex: 1; background-color: transparent; color: var(--umbil-brand-teal);
  border: 1px solid var(--umbil-brand-teal); font-size: 0.9rem; padding: 8px 12px;
  border-radius: var(--umbil-radius-sm); cursor: pointer; display: inline-flex;
  align-items: center; justify-content: center; gap: 8px; transition: all 0.2s;
}
.generate-button:hover { background-color: var(--umbil-hover-bg); }
.generate-button:disabled { opacity: 0.5; cursor: not-allowed; }

.tag-button-container { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
.tag-button {
  background-color: var(--umbil-brand-teal); color: var(--umbil-surface);
  font-size: 0.8rem; font-weight: 500; padding: 4px 10px; border-radius: 12px;
  border: none; cursor: pointer; transition: all 0.2s; opacity: 0.8;
}
.tag-button:hover { opacity: 1; box-shadow: 0 0 5px var(--umbil-focus-ring); }
.auto-tag-label { font-size: 0.8rem; color: var(--umbil-muted); width: 100%; margin-top: 4px; }

/* Quick Tour Styles */
.tour-overlay {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background-color: rgba(0, 0, 0, 0.5); z-index: 1001; cursor: pointer;
}
.tour-highlight-box {
  position: absolute; border-radius: var(--umbil-radius-sm);
  box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.5); border: 2px solid var(--umbil-brand-teal);
  transition: all 0.3s ease-in-out; pointer-events: none;
}
.tour-content-box {
  position: fixed; background-color: var(--umbil-surface); color: var(--umbil-text);
  border-radius: var(--umbil-radius-sm); box-shadow: var(--umbil-shadow-lg);
  padding: 24px; width: 90%; max-width: 320px; z-index: 1002;
  transition: all 0.3s ease-in-out; border-top: 4px solid var(--umbil-brand-teal);
}
.tour-close-button {
  position: absolute; top: 8px; right: 8px; background: none; border: none;
  cursor: pointer; padding: 8px; color: var(--umbil-muted); opacity: 0.7;
  transition: opacity 0.2s; border-radius: 50%;
}
.tour-close-button:hover { opacity: 1; background-color: var(--umbil-hover-bg); }
.tour-title { font-size: 1.25rem; font-weight: 700; color: var(--umbil-text); margin-bottom: 12px; }
.tour-text { font-size: 0.95rem; color: var(--umbil-muted); line-height: 1.6; margin-bottom: 24px; }
.tour-footer {
  display: flex; justify-content: space-between; align-items: center;
  border-top: 1px solid var(--umbil-divider); padding-top: 16px; margin-top: 16px;
}
.tour-step-counter { font-size: 0.85rem; font-weight: 500; color: var(--umbil-muted); }
.tour-buttons { display: flex; gap: 8px; }
.tour-button-back {
  background: none; border: none; color: var(--umbil-muted); font-weight: 600;
  padding: 8px 12px; border-radius: var(--umbil-radius-sm); cursor: pointer; transition: background-color 0.2s;
}
.tour-button-back:hover { background-color: var(--umbil-hover-bg); }
.tour-button-next {
  padding: 8px 12px; border-radius: var(--umbil-radius-sm); font-weight: 600;
  cursor: pointer; transition: background-color 0.2s, color 0.2s, border-color 0.2s;
  font-size: 0.9rem; line-height: 1.5; background-color: var(--umbil-brand-teal);
  color: var(--umbil-surface); border: 1px solid var(--umbil-brand-teal);
}
.tour-button-next:hover { background-color: #1a92a5; border-color: #1a92a5; }

/* Skeleton Loader */
.skeleton-loader {
  animation: shimmer 2s infinite linear;
  background: linear-gradient(to right, var(--umbil-bg) 4%, var(--umbil-hover-bg) 25%, var(--umbil-bg) 36%);
  background-size: 1000px 100%; border-radius: 8px;
}
</file>

<file path="src/app/styles/layout.css">
/* src/app/styles/layout.css */
body {
  font-family: 'Inter', system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
