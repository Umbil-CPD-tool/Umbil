<file path="src/app/styles/theme.css">
/* src/app/styles/theme.css */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');

:root {
  /* Simplified Color Palette (Light Mode Default) */
  --umbil-bg: #f7f8fa;
