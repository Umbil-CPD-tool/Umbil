                        <button onClick={(e) => deleteMsfCycle(cycle.id, e)} className="p-2 text-[var(--umbil-muted)] hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors ml-auto sm:ml-0">
                            <Trash2 size={18} />
                        </button>
                    </div>
                </div>
            );
