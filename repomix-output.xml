                backgroundColor: status.startsWith("❌") ? "#fef2f2" : status.startsWith("🗑️") ? "#fff1f2" : "#ecfdf5",
                color: status.startsWith("❌") ? "#dc2626" : status.startsWith("🗑️") ? "#be123c" : "#047857",
                fontWeight: 600, whiteSpace: "pre-wrap"
              }}>
                {status}
              </div>
            )}

